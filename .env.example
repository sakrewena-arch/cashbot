# ============================================================
# CASHBOT - Configuration
# ============================================================
# Dupliquez ce fichier en .env et remplissez les valeurs
# ============================================================

# === BOT TELEGRAM ===
BOT_TOKEN=votre_token_ici
BOT_USERNAME=cashbot_bot
BOT_WEBHOOK_URL=https://votre-domaine.com/webhook

# === BASE DE DONNÉES ===
DATABASE_URL=postgresql://user:password@localhost:5432/cashbot

# === REDIS ===
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# === JWT ===
JWT_SECRET=une_chaine_tres_longue_et_aleatoire
JWT_EXPIRES_IN=7d

# === ADMIN ===
ADMIN_IDS=123456789,987654321
ADMIN_PANEL_URL=http://localhost:3000

# === API ===
API_PORT=3001
API_URL=http://localhost:3001

# === 26KADO ===
KADO_API_URL=https://api.26kado.com
KADO_API_KEY=votre_cle_api_26kado
KADO_WEBHOOK_SECRET=secret_webhook_26kado

# === STOCKAGE ===
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# === LOGS ===
LOG_LEVEL=debug
LOG_DIR=./logs

# === NOTIFICATIONS ===
NOTIFICATION_BATCH_SIZE=100

# === CACHE ===
CACHE_TTL=300

# === RATE LIMIT ===
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=30

# === CRYPTO (optionnel) ===
CRYPTO_API_KEY=
CRYPTO_WALLET_ADDRESS=

# === PAYPAL (optionnel) ===
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# === SMTP (optionnel) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@cashbot.com